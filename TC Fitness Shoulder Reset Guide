<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>TC Fitness | Shoulder Reset</title>
<style>
  :root {
    --navy: #1B2A4A;
    --gold: #D9BF22;
    --gold-light: #EDD94A;
    --light-gray: #F4F4F4;
    --white: #FFFFFF;
    --text-dark: #1B2A4A;
    --text-mid: #444B5A;
    --text-light: #6B7280;
    --pass-green: #2D6A4F;
    --notyet-red: #9B2226;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: Helvetica, Arial, sans-serif;
    background: var(--light-gray);
    color: var(--text-dark);
    line-height: 1.65;
  }

  /* ── HEADER ── */
  header {
    background: var(--navy);
    color: var(--white);
    padding: 0;
  }

  .header-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 40px;
    border-bottom: 3px solid var(--gold);
  }

  .brand-name {
    font-size: 15px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--gold);
  }

  .header-contact {
    font-size: 11px;
    color: rgba(255,255,255,0.65);
    text-align: right;
    line-height: 1.6;
  }

  .hero {
    padding: 60px 40px 50px;
    text-align: center;
    background: var(--navy);
  }

  .hero-eyebrow {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 16px;
  }

  .hero-title {
    font-size: 54px;
    font-weight: 900;
    color: var(--white);
    line-height: 1.05;
    letter-spacing: -1px;
    margin-bottom: 10px;
  }

  .hero-subtitle {
    font-size: 15px;
    color: rgba(255,255,255,0.72);
    max-width: 520px;
    margin: 0 auto 32px;
    font-style: italic;
  }

  .ideal-for {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 36px;
  }

  .ideal-tag {
    background: rgba(217,191,34,0.15);
    border: 1px solid rgba(217,191,34,0.4);
    color: var(--gold);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    padding: 6px 14px;
    border-radius: 2px;
  }

  .author-block {
    font-size: 13px;
    color: rgba(255,255,255,0.55);
    line-height: 1.7;
  }

  .author-block strong {
    color: var(--white);
    font-size: 14px;
  }

  /* ── NAV ── */
  nav {
    background: var(--gold);
    padding: 0 40px;
    display: flex;
    gap: 0;
    overflow-x: auto;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  nav a {
    color: var(--navy);
    text-decoration: none;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    padding: 13px 16px;
    white-space: nowrap;
    border-bottom: 3px solid transparent;
    transition: border-color 0.2s;
  }

  nav a:hover {
    border-bottom-color: var(--navy);
  }

  /* ── LAYOUT ── */
  .page-wrap {
    max-width: 860px;
    margin: 0 auto;
    padding: 0 24px;
  }

  section {
    padding: 64px 0;
    border-bottom: 1px solid #ddd;
  }

  section:last-of-type { border-bottom: none; }

  .section-label {
    display: inline-block;
    background: var(--navy);
    color: var(--gold);
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 3px;
    text-transform: uppercase;
    padding: 5px 14px;
    margin-bottom: 28px;
  }

  h2 {
    font-size: 28px;
    font-weight: 900;
    color: var(--navy);
    margin-bottom: 16px;
    line-height: 1.2;
  }

  h3 {
    font-size: 18px;
    font-weight: 800;
    color: var(--navy);
    margin-bottom: 10px;
  }

  p { margin-bottom: 14px; color: var(--text-mid); }

  ul {
    list-style: none;
    margin-bottom: 16px;
  }

  ul li {
    padding: 5px 0 5px 20px;
    position: relative;
    color: var(--text-mid);
  }

  ul li::before {
    content: "►";
    position: absolute;
    left: 0;
    color: var(--gold);
    font-size: 10px;
    top: 7px;
  }

  .callout {
    background: var(--navy);
    color: var(--white);
    padding: 20px 24px;
    margin: 24px 0;
    border-left: 4px solid var(--gold);
  }

  .callout strong { color: var(--gold); }
  .callout p { color: rgba(255,255,255,0.85); margin: 0; }

  /* ── INTRO TABLE ── */
  .toc-grid {
    display: grid;
    grid-template-columns: 120px 1fr;
    gap: 0;
    border: 1px solid #ddd;
    margin: 28px 0;
  }

  .toc-row {
    display: contents;
  }

  .toc-label, .toc-text {
    padding: 10px 16px;
    font-size: 13px;
    border-bottom: 1px solid #ddd;
  }

  .toc-label {
    background: var(--navy);
    color: var(--gold);
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 1.5px;
    text-transform: uppercase;
  }

  .toc-text { background: var(--white); color: var(--text-mid); }

  /* ── EXERCISE CARDS ── */
  .exercise-overview-table {
    width: 100%;
    border-collapse: collapse;
    margin: 28px 0;
    font-size: 14px;
  }

  .exercise-overview-table th {
    background: var(--navy);
    color: var(--gold);
    padding: 10px 16px;
    text-align: left;
    font-size: 11px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    font-weight: 800;
  }

  .exercise-overview-table td {
    padding: 12px 16px;
    border-bottom: 1px solid #ddd;
    color: var(--text-mid);
    background: var(--white);
  }

  .exercise-overview-table td:first-child {
    font-weight: 900;
    color: var(--gold);
    font-size: 18px;
    width: 48px;
  }

  .exercise-overview-table tr:last-child td { border-bottom: none; }

  .exercise-card {
    background: var(--white);
    border: 1px solid #ddd;
    margin: 40px 0;
    overflow: hidden;
  }

  .exercise-card-header {
    background: var(--navy);
    padding: 20px 24px;
    display: flex;
    align-items: baseline;
    gap: 14px;
  }

  .ex-number {
    font-size: 36px;
    font-weight: 900;
    color: var(--gold);
    line-height: 1;
    opacity: 0.7;
  }

  .ex-title-block {}
  .ex-number-label { font-size: 11px; font-weight: 800; letter-spacing: 2px; color: var(--gold); text-transform: uppercase; }
  .ex-name { font-size: 22px; font-weight: 900; color: var(--white); line-height: 1.1; }
  .ex-subtitle { font-size: 13px; color: rgba(255,255,255,0.6); font-style: italic; margin-top: 2px; }

  .exercise-card-body {
    padding: 24px;
  }

  .ex-section-title {
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 6px;
    margin-top: 20px;
  }

  .ex-section-title:first-child { margin-top: 0; }

  .cue-list {
    list-style: none;
    margin-bottom: 0;
  }

  .cue-list li {
    padding: 6px 0 6px 22px;
    position: relative;
    font-size: 14px;
    color: var(--text-mid);
    border-bottom: 1px solid var(--light-gray);
  }

  .cue-list li:last-child { border-bottom: none; }

  .cue-list li::before {
    content: "—";
    position: absolute;
    left: 0;
    color: var(--gold);
    font-weight: 900;
  }

  .rx-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 1px;
    background: #ddd;
    margin-top: 20px;
    border: 1px solid #ddd;
  }

  .rx-cell {
    background: var(--white);
    padding: 14px 16px;
  }

  .rx-cell-label {
    font-size: 9px;
    font-weight: 800;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--text-light);
    margin-bottom: 6px;
  }

  .rx-cell.starter .rx-cell-label { color: var(--navy); }
  .rx-cell.progression .rx-cell-label { color: #2D6A4F; }
  .rx-cell.regression .rx-cell-label { color: #9B2226; }

  .rx-cell p {
    font-size: 13px;
    color: var(--text-mid);
    margin: 0;
    line-height: 1.5;
  }

  .key-cue {
    background: var(--navy);
    border-left: 4px solid var(--gold);
    padding: 12px 18px;
    margin-top: 20px;
    font-size: 14px;
    color: rgba(255,255,255,0.85);
    font-style: italic;
  }

  .key-cue strong { color: var(--gold); font-style: normal; }

  /* ── WEEKLY PLAN ── */
  .schedule-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 13px;
    margin: 24px 0;
  }

  .schedule-table th {
    background: var(--navy);
    color: var(--gold);
    padding: 10px 14px;
    text-align: left;
    font-size: 10px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
  }

  .schedule-table td {
    padding: 10px 14px;
    border-bottom: 1px solid #eee;
    background: var(--white);
    color: var(--text-mid);
    vertical-align: top;
  }

  .schedule-table td:first-child {
    font-weight: 800;
    color: var(--navy);
    white-space: nowrap;
  }

  .schedule-table tr:last-child td { border-bottom: none; }

  .ex-mini-list {
    list-style: none;
    margin: 0;
  }

  .ex-mini-list li {
    padding: 2px 0;
    font-size: 12px;
    color: var(--text-mid);
  }

  .ex-mini-list li::before { display: none; }

  /* ── SELF-ASSESSMENT ── */
  .assessment-card {
    background: var(--white);
    border: 1px solid #ddd;
    margin: 24px 0;
    overflow: hidden;
  }

  .assessment-card-header {
    background: var(--navy);
    color: var(--white);
    padding: 14px 20px;
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .assessment-num {
    font-size: 28px;
    font-weight: 900;
    color: var(--gold);
    line-height: 1;
    min-width: 36px;
  }

  .assessment-name {
    font-size: 16px;
    font-weight: 800;
    color: var(--white);
  }

  .assessment-card-body {
    padding: 20px 24px;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 24px;
  }

  .assessment-content { flex: 1; }

  .assessment-content p {
    font-size: 14px;
    color: var(--text-mid);
    margin-bottom: 6px;
  }

  .pass-criteria {
    font-size: 13px;
    color: var(--navy);
    font-weight: 700;
    margin-top: 8px;
    padding: 8px 12px;
    background: var(--light-gray);
    border-left: 3px solid var(--gold);
  }

  .assessment-buttons {
    display: flex;
    flex-direction: column;
    gap: 8px;
    min-width: 110px;
    align-items: stretch;
  }

  .btn-pass, .btn-notyet {
    padding: 10px 14px;
    font-family: Helvetica, Arial, sans-serif;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 1px;
    text-transform: uppercase;
    border: 2px solid;
    cursor: pointer;
    border-radius: 0;
    transition: all 0.15s;
  }

  .btn-pass {
    background: transparent;
    border-color: var(--pass-green);
    color: var(--pass-green);
  }

  .btn-pass.selected {
    background: var(--pass-green);
    color: var(--white);
  }

  .btn-notyet {
    background: transparent;
    border-color: var(--notyet-red);
    color: var(--notyet-red);
  }

  .btn-notyet.selected {
    background: var(--notyet-red);
    color: var(--white);
  }

  .score-display {
    background: var(--navy);
    color: var(--white);
    padding: 24px;
    margin: 24px 0;
    text-align: center;
  }

  .score-label { font-size: 11px; letter-spacing: 2px; text-transform: uppercase; color: rgba(255,255,255,0.55); margin-bottom: 6px; }
  .score-number { font-size: 52px; font-weight: 900; color: var(--gold); line-height: 1; }
  .score-total { font-size: 16px; color: rgba(255,255,255,0.55); }
  .score-meaning { font-size: 14px; color: rgba(255,255,255,0.8); margin-top: 10px; font-style: italic; }

  .score-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 13px;
    margin-top: 20px;
  }

  .score-table th {
    background: var(--navy);
    color: var(--gold);
    padding: 9px 14px;
    text-align: left;
    font-size: 10px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
  }

  .score-table td {
    padding: 10px 14px;
    border-bottom: 1px solid #eee;
    background: var(--white);
    color: var(--text-mid);
    vertical-align: top;
  }

  .score-table tr:last-child td { border-bottom: none; }

  /* ── TIMELINE ── */
  .timeline {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: #ddd;
    border: 1px solid #ddd;
    margin: 24px 0;
  }

  .timeline-phase {
    background: var(--white);
    padding: 20px;
  }

  .timeline-weeks {
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 10px;
  }

  .timeline-phase ul { margin: 0; }

  .timeline-phase ul li {
    padding: 4px 0 4px 16px;
    font-size: 13px;
    color: var(--text-mid);
  }

  .timeline-phase ul li::before {
    content: "✓";
    color: var(--pass-green);
    font-size: 11px;
    top: 6px;
  }

  /* ── TRACKER ── */
  .tracker-grid {
    width: 100%;
    border-collapse: collapse;
    font-size: 13px;
    margin: 20px 0;
  }

  .tracker-grid th {
    background: var(--navy);
    color: var(--gold);
    padding: 9px 14px;
    text-align: left;
    font-size: 10px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
  }

  .tracker-grid td {
    padding: 10px 14px;
    border-bottom: 1px solid #eee;
    background: var(--white);
    vertical-align: middle;
  }

  .tracker-grid td:first-child {
    font-weight: 800;
    color: var(--navy);
    white-space: nowrap;
  }

  .tracker-grid tr:last-child td { border-bottom: none; }

  .workout-check {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .workout-checkbox {
    width: 20px;
    height: 20px;
    border: 2px solid var(--navy);
    border-radius: 0;
    cursor: pointer;
    background: transparent;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.15s;
    font-size: 13px;
    font-weight: 900;
    color: transparent;
    user-select: none;
  }

  .workout-checkbox.checked {
    background: var(--navy);
    color: var(--gold);
  }

  .date-input {
    border: none;
    border-bottom: 1px solid #ccc;
    font-family: Helvetica, Arial, sans-serif;
    font-size: 12px;
    color: var(--text-mid);
    width: 100px;
    padding: 2px 4px;
    background: transparent;
    outline: none;
  }

  .date-input:focus { border-bottom-color: var(--navy); }
  .date-input::placeholder { color: #bbb; }

  .notes-area {
    width: 100%;
    border: 1px solid #ddd;
    font-family: Helvetica, Arial, sans-serif;
    font-size: 13px;
    color: var(--text-mid);
    padding: 12px;
    resize: vertical;
    min-height: 80px;
    outline: none;
    background: var(--white);
  }

  .notes-area:focus { border-color: var(--navy); }

  /* ── TESTIMONIAL ── */
  .testimonial {
    background: var(--navy);
    padding: 32px 36px;
    margin: 24px 0;
    position: relative;
  }

  .testimonial::before {
    content: "\201C";
    position: absolute;
    top: 10px;
    left: 24px;
    font-size: 80px;
    color: var(--gold);
    opacity: 0.3;
    font-family: Georgia, serif;
    line-height: 1;
  }

  .testimonial blockquote {
    font-size: 16px;
    color: rgba(255,255,255,0.88);
    font-style: italic;
    line-height: 1.75;
    margin-bottom: 16px;
    padding-left: 16px;
  }

  .testimonial cite {
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--gold);
    padding-left: 16px;
  }

  /* ── DISCLAIMER ── */
  .disclaimer-box {
    background: var(--white);
    border: 1px solid #ddd;
    border-left: 4px solid var(--navy);
    padding: 20px 24px;
    margin: 20px 0;
  }

  .disclaimer-box h3 { margin-bottom: 10px; font-size: 15px; }
  .disclaimer-box p { font-size: 13px; color: var(--text-light); margin: 0; }

  /* ── CTA ── */
  .cta-section {
    background: var(--navy);
    padding: 56px 40px;
    text-align: center;
  }

  .cta-section h2 {
    color: var(--white);
    font-size: 30px;
    margin-bottom: 16px;
  }

  .cta-section p {
    color: rgba(255,255,255,0.75);
    max-width: 560px;
    margin: 0 auto 24px;
  }

  .cta-benefits {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
    max-width: 500px;
    margin: 0 auto 32px;
    text-align: left;
  }

  .cta-benefit {
    font-size: 13px;
    color: rgba(255,255,255,0.8);
    padding: 8px 12px;
    background: rgba(255,255,255,0.07);
    border-left: 3px solid var(--gold);
  }

  .cta-btn {
    display: inline-block;
    background: var(--gold);
    color: var(--navy);
    font-family: Helvetica, Arial, sans-serif;
    font-size: 13px;
    font-weight: 900;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 16px 36px;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: background 0.15s;
  }

  .cta-btn:hover { background: var(--gold-light); }

  .cta-contact {
    margin-top: 18px;
    font-size: 12px;
    color: rgba(255,255,255,0.4);
  }

  /* ── FOOTER ── */
  footer {
    background: #111B2D;
    color: rgba(255,255,255,0.45);
    text-align: center;
    padding: 24px 40px;
    font-size: 11px;
    line-height: 1.8;
    border-top: 3px solid var(--gold);
  }

  /* ── PAIN RULE ── */
  .pain-rule {
    background: #FFF8F8;
    border: 1px solid #E5C0C0;
    border-left: 4px solid var(--notyet-red);
    padding: 18px 22px;
    margin: 24px 0;
  }

  .pain-rule strong { color: var(--notyet-red); display: block; margin-bottom: 8px; font-size: 13px; letter-spacing: 0.5px; }
  .pain-rule ul li { color: var(--text-mid); font-size: 13px; }
  .pain-rule ul li::before { color: var(--notyet-red); }

  /* ── RESPONSIVE ── */
  @media (max-width: 640px) {
    .hero-title { font-size: 36px; }
    .timeline { grid-template-columns: 1fr; }
    .rx-grid { grid-template-columns: 1fr; }
    .cta-benefits { grid-template-columns: 1fr; }
    .assessment-card-body { flex-direction: column; }
    .assessment-buttons { flex-direction: row; min-width: unset; }
    .header-top { flex-direction: column; gap: 8px; text-align: center; }
    nav { padding: 0 16px; }
    .hero { padding: 40px 20px 36px; }
    section { padding: 44px 0; }
  }
</style>
</head>
