<script>
  // Assessment Logic
  const assessmentState = { q1: null, q2: null, q3: null, q4: null, q5: null };

  function toggleAssessment(btn, type, question) {
    const card = btn.closest('.assessment-card-body');
    const passBtn = card.querySelector('.btn-pass');
    const notyetBtn = card.querySelector('.btn-notyet');

    // If clicking the already-selected button, deselect
    if (assessmentState[question] === type) {
      assessmentState[question] = null;
      passBtn.classList.remove('selected');
      notyetBtn.classList.remove('selected');
    } else {
      assessmentState[question] = type;
      passBtn.classList.remove('selected');
      notyetBtn.classList.remove('selected');
      btn.classList.add('selected');
    }
    updateScore();
  }

  function updateScore() {
    const answered = Object.values(assessmentState).filter(v => v !== null).length;
    if (answered === 0) {
      document.getElementById('scoreNumber').textContent = '—';
      document.getElementById('scoreMeaning').textContent = 'Complete the assessment above to see your score.';
      return;
    }
    const passes = Object.values(assessmentState).filter(v => v === 'pass').length;
    document.getElementById('scoreNumber').textContent = passes;

    const meanings = {
      5: 'Strong Baseline — Follow the Weekly Plan. Progress one variable every 1–2 weeks.',
      4: 'Solid Foundation — Focus extra attention on exercises where you scored Not Yet.',
      3: 'Solid Foundation — Focus extra attention on exercises where you scored Not Yet.',
      2: 'Opportunity Zone — Use regression versions of all four exercises. Build slowly.',
      1: 'Opportunity Zone — Use regression versions of all four exercises. Build slowly.',
      0: 'Start Here — Begin with wall slides and posture work daily. Consider personalized coaching.'
    };

    if (answered === 5) {
      document.getElementById('scoreMeaning').textContent = meanings[passes];
    } else {
      document.getElementById('scoreMeaning').textContent = `${answered} of 5 completed — finish the assessment to see your full score.`;
    }
  }

  // Build Tracker
  const tbody = document.getElementById('trackerBody');
  for (let w = 1; w <= 8; w++) {
    const tr = document.createElement('tr');
    tr.innerHTML = `
      <td><strong>Week ${w}</strong></td>
      ${['A','B','C'].map(letter => `
        <td>
          <div class="workout-check">
            <div class="workout-checkbox" onclick="toggleCheck(this)" title="Click to check off">✓</div>
            <input class="date-input" type="text" placeholder="Date" />
          </div>
        </td>
      `).join('')}
    `;
    tbody.appendChild(tr);
  }

  function toggleCheck(el) {
    el.classList.toggle('checked');
  }
</script>

